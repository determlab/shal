# Source distribution contents. Wheel data files are handled by package-data in
# pyproject.toml; this governs the sdist tarball.
include LICENSE
include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include pyproject.toml
recursive-include src/shal *.json py.typed
recursive-include docs *.md
prune docs/design          # design/decision docs live in-repo only, not in the package

# Keep examples, tests, and the new-user eval trial out of the tarball.
prune examples
prune tests
prune eval
global-exclude __pycache__ *.py[cod]
