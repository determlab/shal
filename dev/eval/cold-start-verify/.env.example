# Copy to .env and fill. NEVER commit .env (see .gitignore). SHAL auto-loads a .env beside
# the topology and resolves ${VAR}. Inline ` # comments` and blank-with-comment values are
# handled (a value that is only a comment = unset) — but keep secrets on their own clean line.

# --- Deebot (Ecovacs cloud; unofficial API; needs Python 3.11+) ---
ECOVACS_EMAIL=
ECOVACS_PASSWORD=
ECOVACS_COUNTRY=US
ECOVACS_CONTINENT=ww
ECOVACS_DEVICE=

# --- Sonos (LAN; leave blank to auto-discover) ---
SONOS_HOST=
