{
  "name": "root",
  "children": {
    "i2c0": {
      "bus": "i2c", "addr": "/dev/i2c-1",
      "children": {
        "temp":  {"id": "ambient", "driver": "ti,tmp102", "addr": "0x48"},
        "mux":   {
          "bus": "i2c-mux", "addr": "0x70",
          "children": {
            "tA": {"id": "tempA", "driver": "ti,tmp102", "addr": "ch0:0x48"},
            "tB": {"id": "tempB", "driver": "ti,tmp102", "addr": "ch1:0x48"}
          }
        }
      }
    },
    "spi0":  {"bus": "spi",  "addr": "spidev0.0",     "children": {"imu": {"id": "imu", "driver": "bosch,bmi160", "addr": "cs0"}}},
    "uart0": {"bus": "uart", "addr": "/dev/ttyS0",    "children": {"gps": {"id": "gps", "driver": "ublox,neo6m", "addr": "-"}}},
    "pci0":  {"bus": "pcie", "addr": "0000:01:00.0",  "children": {"nic": {"id": "nic", "driver": "intel,e1000", "addr": "bar0"}}},
    "usb0":  {"bus": "usb",  "addr": "usb1",          "children": {"uth": {"id": "usbtemp", "driver": "generic,usb-thermo", "addr": "ep1"}}}
  }
}
