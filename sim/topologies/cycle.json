{
  "name": "root",
  "children": {
    "srv": {
      "id": "server", "bus": "ssh", "addr": "user@srv",
      "children": {
        "i2c": {
          "bus": "i2c", "addr": "/dev/i2c-1",
          "children": {"t": {"id": "ct", "driver": "ti,tmp102", "addr": "0x48"}}
        },
        "pc": {
          "id": "pc", "bus": "ssh", "addr": "user@pc",
          "children": {"back": {"ref": "$server"}}
        }
      }
    }
  }
}
