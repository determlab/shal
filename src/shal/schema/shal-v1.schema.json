{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shal.dev/schemas/shal-v1.schema.json",
  "title": "SHAL topology file, shal_version 1",
  "description": "Structural validation of a SHAL topology. Semantic checks (id uniqueness, per-bus-family address grammar, driver installed, $ref resolution, transport-kind compatibility) happen at load, after schema validation.",
  "type": "object",
  "required": ["shal_version"],
  "additionalProperties": false,
  "anyOf": [
    { "required": ["root"] },
    { "required": ["template"] }
  ],
  "properties": {
    "shal_version": { "const": 1 },
    "root": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/nodeName" },
      "additionalProperties": { "$ref": "#/$defs/node" }
    },
    "template": { "$ref": "#/$defs/node" }
  },
  "$defs": {
    "nodeName": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "compatible": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*,[a-z0-9][a-z0-9_.-]*$"
    },
    "address": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "integer", "minimum": 0 }
      ]
    },
    "path": {
      "type": "string",
      "pattern": "^(/[a-z0-9][a-z0-9_-]*)+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^\\$[a-z0-9][a-z0-9_-]*$"
    },
    "route": {
      "type": "object",
      "required": ["via", "address"],
      "additionalProperties": false,
      "properties": {
        "via": { "$ref": "#/$defs/path" },
        "address": { "$ref": "#/$defs/address" }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "description": { "type": "string" },
        "expose": { "type": "boolean" },
        "driver": { "$ref": "#/$defs/compatible" },
        "from": { "type": "string", "minLength": 1 },
        "address": { "$ref": "#/$defs/address" },
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/route" }
        },
        "to": { "$ref": "#/$defs/ref" },
        "use": { "type": "string", "minLength": 1 },
        "with": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        },
        "children": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/nodeName" },
          "additionalProperties": { "$ref": "#/$defs/node" }
        },
        "watchdog_ms": { "type": "integer", "minimum": 1 },
        "verify": { "type": "boolean" },
        "insecure": { "type": "boolean" },
        "config": {
          "type": "object",
          "description": "Bus/driver-specific parameters. String values of the form ${ENV_VAR} resolve from the environment at load (the documented home for secrets); literals are the local-file convenience.",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      },
      "allOf": [
        {
          "comment": "A use: node draws address/routes/to from its template, so it is exempt from the one-of-those constraint that ordinary nodes obey.",
          "if": { "not": { "required": ["use"] } },
          "then": {
            "oneOf": [
              { "required": ["address"], "not": { "anyOf": [{ "required": ["routes"] }, { "required": ["to"] }] } },
              { "required": ["routes"], "not": { "anyOf": [{ "required": ["address"] }, { "required": ["to"] }] } },
              { "required": ["to"], "not": { "anyOf": [{ "required": ["address"] }, { "required": ["routes"] }, { "required": ["children"] }] } }
            ]
          }
        }
      ]
    }
  }
}
